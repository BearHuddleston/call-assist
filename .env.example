# Keep true for a fully local, judge-safe experience without API calls.
CALL_ASSIST_DEMO_MODE=true

# Set demo mode to false and provide a key to generate plans and outcomes with GPT-5.6.
OPENAI_API_KEY=
OPENAI_PLANNING_MODEL=gpt-5.6-sol
OPENAI_PLANNING_REASONING_EFFORT=low
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REALTIME_VOICE=marin
OPENAI_TRACING_DISABLED=true

# Comma-separated E.164 numbers. Add a real test destination before placing a live call.
# The two built-in 555 demo numbers are always allowed by the UI but are not routable.
CALL_ASSIST_ALLOWLIST=

# Browser app -> private telephony service. Use the same long random token in both processes.
TELEPHONY_SERVICE_URL=http://127.0.0.1:8788
CALL_ASSIST_SERVICE_TOKEN=

# Telephony service -> public Twilio webhooks and Media Stream.
TELEPHONY_PORT=8788
TELEPHONY_HOST=0.0.0.0
TELEPHONY_PUBLIC_BASE_URL=https://your-tunnel.example
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE_SIGNATURES=true
