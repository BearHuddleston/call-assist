{
  "name": "call-assist",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "telephony:dev": "node --env-file-if-exists=.env.local --import tsx --watch server/index.ts",
    "telephony:start": "node --env-file-if-exists=.env.local --import tsx server/index.ts",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "node --test tests/contracts.test.mjs tests/safety.test.mjs tests/live-call.test.mjs tests/openai.test.mjs tests/plan-simulation.test.mjs tests/prompts.test.mjs tests/telephony-smoke.test.mjs",
    "test:render": "npm run build && node --test tests/rendered-html.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/websocket": "^11.3.0",
    "@openai/agents": "^0.13.5",
    "@openai/agents-extensions": "^0.13.5",
    "fastify": "^5.10.0",
    "next": "16.2.6",
    "openai": "^6.48.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/workers-types": "^5.20260719.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "postcss": "8.5.14",
    "ws": "8.21.1"
  },
  "type": "module"
}
